Class AustMAP01BlueKeyAnchor : Actor
{
Default
{
+MOVEWITHSECTOR
Radius 8;
Height 8;
}
States
{
Spawn:
TNT1 A 1 A_SpawnItemEx("AustMAP01BlueKeyLight",8,0, -16);
Loop;
}
}

