Class AustMAP01BlueMiniAnchor : SwitchableDecoration
{
Default
{
+MOVEWITHSECTOR
Radius 8;
Height 8;
}
States
{
Spawn:
Inactive:
TNT1 A -1;
Stop;
Active:
TNT1 A 1 A_SpawnItemEx("AustMAP01BlueMiniLight",8,0, -32);
Loop;
}
}

